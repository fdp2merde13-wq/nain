local function drawRect(x, y, w, h, r, g, b, a)
    DrawRect(x, y, w, h, r, g, b, math.floor(a * menuAlpha))
end
local function drawBorderRect(x, y, w, h, fr, fg, fb, fa, br, bg, bb, ba)
    DrawRect(x, y, w, h, fr, fg, fb, math.floor(fa * menuAlpha))
    local t = 0.0018
    DrawRect(x - w/2 + t/2, y, t, h, br, bg, bb, math.floor(ba * menuAlpha))
    DrawRect(x + w/2 - t/2, y, t, h, br, bg, bb, math.floor(ba * menuAlpha))
    DrawRect(x, y - h/2 + t/2, w, t, br, bg, bb, math.floor(ba * menuAlpha))
    DrawRect(x, y + h/2 - t/2, w, t, br, bg, bb, math.floor(ba * menuAlpha))
end

local function drawText(text, x, y, scale, centered, r, g, b, a, font)
    SetTextFont(font or UI_FONTS.option)
    SetTextScale(scale, scale)
    SetTextColour(
        r or UI_COLORS.text[1],
        g or UI_COLORS.text[2],
        b or UI_COLORS.text[3],
        math.floor((a or UI_COLORS.text[4]) * menuAlpha)
    )
    if centered then SetTextCentre(true) end
    SetTextOutline()
    BeginTextCommandDisplayText("STRING")
    AddTextComponentSubstringPlayerName(text)
    EndTextCommandDisplayText(x, y)
end

local function drawChamferRect(x, y, w, h, r, cr, cg, cb, ca)
    local rr = r or UI_METRICS.corner_radius
    drawRect(x, y, w - 2 * rr, h, cr, cg, cb, ca)
    drawRect(x - (w / 2 - rr / 2), y, rr, h - 2 * rr, cr, cg, cb, ca)
    drawRect(x + (w / 2 - rr / 2), y, rr, h - 2 * rr, cr, cg, cb, ca)
    drawRect(x, y - (h / 2 - rr / 2), w - 2 * rr, rr, cr, cg, cb, ca)
    drawRect(x, y + (h / 2 - rr / 2), w - 2 * rr, rr, cr, cg, cb, ca)
end

local function drawNeonOutline(x, y, w, h, r, g, b, a)
    drawRect(x - w/2 + 0.002, y, 0.002, h, r, g, b, a)
    drawRect(x + w/2 - 0.002, y, 0.002, h, r, g, b, a)
    drawRect(x, y - h/2 + 0.002, w, 0.002, r, g, b, a)
    drawRect(x, y + h/2 - 0.002, w, 0.002, r, g, b, a)
end

local function drawRoundedRect(x, y, w, h, r, cr, cg, cb, ca)
    local rr = math.max(0.0, math.min(r or UI_METRICS.corner_radius, math.min(w, h) / 2.0))
    if rr <= 0.001 then
        drawRect(x, y, w, h, cr, cg, cb, ca)
        return
    end
    drawRect(x, y, w - 2 * rr, h, cr, cg, cb, ca)
    drawRect(x - (w / 2 - rr / 2), y, rr, h - 2 * rr, cr, cg, cb, ca)
    drawRect(x + (w / 2 - rr / 2), y, rr, h - 2 * rr, cr, cg, cb, ca)
    local N = 8
    local segH = (2 * rr) / N
    for i = 0, N - 1 do
        local yLocal = -rr + (i + 0.5) * segH
        local xOff = math.sqrt(math.max(0.0, rr * rr - yLocal * yLocal))
        local stripW = w - 2 * (rr - xOff)
        local yTop = y - h / 2 + rr + yLocal
        local yBot = y + h / 2 - rr + yLocal
        drawRect(x, yTop, stripW, segH, cr, cg, cb, ca)
        drawRect(x, yBot, stripW, segH, cr, cg, cb, ca)
    end
end

