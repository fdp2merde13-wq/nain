local function scanResources()
    auditResults = {}
    local n = GetNumResources()
    for i = 0, n - 1 do
        local name = GetResourceByFindIndex(i)
        if name and type(name) == "string" and #name > 0 then
            local lower = string.lower(name)
            local score = 0
            for _, kw in ipairs(auditKeywords) do
                if string.find(lower, kw, 1, true) then
                    score = score + (kw == "anticheat" and 6 or kw == "ac" and 3 or 2)
                end
            end
            if score > 0 then
                table.insert(auditResults, {name = name, score = score})
            end
        end
    end
    table.sort(auditResults, function(a, b) return a.score > b.score end)
end
