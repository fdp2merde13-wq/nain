local function GetVehicleInFront(ped)
    local origin = GetEntityCoords(ped)
    local fwd = GetEntityForwardVector(ped)
    local start = vector3(origin.x, origin.y, origin.z + 0.5)
    local finish = vector3(origin.x + fwd.x * 3.0, origin.y + fwd.y * 3.0, origin.z + 0.5 + fwd.z * 3.0)
    local ray = StartShapeTestRay(start.x, start.y, start.z, finish.x, finish.y, finish.z, 2, ped, 0)
    local _, hit, hitCoords, _, entityHit = GetShapeTestResult(ray)
    if hit and entityHit and entityHit ~= 0 then
        local model = GetEntityModel(entityHit)
        if IsModelAVehicle(model) then
            return entityHit
        end
    end
    local bestVeh = nil
    local bestDot = 0.5
    local vehHandle, veh = FindFirstVehicle()
    local success
    repeat
        if DoesEntityExist(veh) then
            local vcoords = GetEntityCoords(veh)
            local toVeh = vector3(vcoords.x - origin.x, vcoords.y - origin.y, vcoords.z - origin.z)
            local dist = #(toVeh)
            if dist < 4.0 then
                local dir2D = vector3(toVeh.x, toVeh.y, 0.0)
                local f2D = vector3(fwd.x, fwd.y, 0.0)
                local magDir = #(dir2D)
                local magF = #(f2D)
                if magDir > 0.001 and magF > 0.001 then
                    local dot = (dir2D.x * f2D.x + dir2D.y * f2D.y) / (magDir * magF)
                    if dot > bestDot then
                        bestDot = dot
                        bestVeh = veh
                    end
                end
            end
        end
        success, veh = FindNextVehicle(vehHandle)
    until not success
    EndFindVehicle(vehHandle)
    return bestVeh
end

local function PropelVehicle(veh, ped)
    if not DoesEntityExist(veh) then return end
    if NetworkGetEntityIsNetworked(veh) then
        NetworkRequestControlOfEntity(veh)
        local timeout = 0
        while not NetworkHasControlOfEntity(veh) and timeout < 50 do
            NetworkRequestControlOfEntity(veh)
            Wait(10)
            timeout = timeout + 1
        end
    end
    local camRot = GetGameplayCamRot(0)
    local yaw = (camRot.z * math.pi) / 180.0
    local pitch = (camRot.x * math.pi) / 180.0
    local dir = vector3(-math.cos(pitch) * math.sin(yaw), math.cos(pitch) * math.cos(yaw), math.sin(pitch))
    ApplyForceToEntityCenterOfMass(veh, 1, dir.x * onePunchForce, dir.y * onePunchForce, onePunchUp, false, true, true)
    SetEntityVelocity(veh, dir.x * onePunchForce, dir.y * onePunchForce, onePunchUp)
end

local function StealVehicleF4()
    local ped = PlayerPedId()
    if ped == 0 then return end
    local veh = GetVehicleInFront(ped)
    if not veh or veh == 0 then
        local origin = GetEntityCoords(ped)
        local nearest, ndist = nil, 9999.0
        local h, v = FindFirstVehicle()
        local ok = true
        while ok do
            if DoesEntityExist(v) then
                local c = GetEntityCoords(v)
                local d = #(c - origin)
                if d < ndist then
                    nearest = v
                    ndist = d
                end
            end
            ok, v = FindNextVehicle(h)
        end
        EndFindVehicle(h)
        veh = nearest
    end
    if not veh or veh == 0 then return end
    if NetworkGetEntityIsNetworked(veh) then
        NetworkRequestControlOfEntity(veh)
        local timeout = 0
        while not NetworkHasControlOfEntity(veh) and timeout < 60 do
            NetworkRequestControlOfEntity(veh)
            Wait(10)
            timeout = timeout + 1
        end
    end
    SetEntityAsMissionEntity(veh, true, true)
    local driver = GetPedInVehicleSeat(veh, -1)
    if driver ~= 0 and driver ~= ped then
        TaskLeaveVehicle(driver, veh, 0)
        local tries = 0
        while GetPedInVehicleSeat(veh, -1) == driver and tries < 40 do
            Wait(50)
            tries = tries + 1
        end
        if GetPedInVehicleSeat(veh, -1) == driver then
            ClearPedTasksImmediately(driver)
            local vc = GetEntityCoords(veh)
            SetEntityCoords(driver, vc.x + 1.5, vc.y + 1.5, vc.z + 0.2, false, false, false, true)
        end
    end
    TaskWarpPedIntoVehicle(ped, veh, -1)
end

local function WarpIntoVehicle()
    local ped = PlayerPedId()
    if ped == 0 then return end
    local veh = GetVehicleInFront(ped)
    if not veh or veh == 0 then return end
    if NetworkGetEntityIsNetworked(veh) then
        NetworkRequestControlOfEntity(veh)
        local timeout = 0
        while not NetworkHasControlOfEntity(veh) and timeout < 60 do
            NetworkRequestControlOfEntity(veh)
            Wait(10)
            timeout = timeout + 1
        end
    end
    local model = GetEntityModel(veh)
    local seats = GetVehicleModelNumberOfSeats(model) or 1
    local targetSeat = nil
    if IsVehicleSeatFree(veh, -1) then
        targetSeat = -1
    else
        for seat = 0, (seats - 2) do
            if IsVehicleSeatFree(veh, seat) then
                targetSeat = seat
                break
            end
        end
    end
    if targetSeat ~= nil then
        TaskWarpPedIntoVehicle(ped, veh, targetSeat)
    end
end

