function AdminMenu.CreateMenu(id, title)
    menus[id] = {}
    menus[id].title = title
    menus[id].visible = false
    menus[id].x = 0.015
    menus[id].y = 0.10
    menus[id].width = UI_METRICS.menu_width
    menus[id].currentOption = 1
end

function AdminMenu.CreateSubMenu(id, parent)
    if menus[parent] then
        AdminMenu.CreateMenu(id, menus[parent].title)
        menus[id].previousMenu = parent
        menus[id].x = menus[parent].x
        menus[id].y = menus[parent].y
        menus[id].width = menus[parent].width
    end
end

