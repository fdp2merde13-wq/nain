local function applyScale(x, y)
    local centerX, centerY = 0.5, 0.5
    local dx, dy = (x - centerX) * menuScale, (y - centerY) * menuScale
    return centerX + dx, centerY + dy
end

local function button(text, state)
    if menus[currentMenu] then
        optionCount = optionCount + 1
        local isCurrent = menus[currentMenu].currentOption == optionCount

        local x = menus[currentMenu].x + menus[currentMenu].width / 2
        local targetY = menus[currentMenu].y + UI_METRICS.option_top + (UI_METRICS.option_spacing * optionCount)

        if not smoothOptionY[optionCount] then 
            smoothOptionY[optionCount] = targetY 
        end

        smoothOptionY[optionCount] = smoothOptionY[optionCount] + (targetY - smoothOptionY[optionCount]) * 0.12

        local y = smoothOptionY[optionCount]
        local w = menus[currentMenu].width
        local h = UI_METRICS.option_height

        x, y = applyScale(x, y)
        w, h = w * menuScale, h * menuScale
        x = x + menuOffsetX

        if highlightY == nil then
            highlightY = y
        end

        if isCurrent then
            highlightY = highlightY + (y - highlightY) * 0.12
        end

        drawBorderRect(x, y, w, h, UI_COLORS.background[1], UI_COLORS.background[2], UI_COLORS.background[3], 180, UI_COLORS.box_border[1], UI_COLORS.box_border[2], UI_COLORS.box_border[3], UI_COLORS.box_border[4])
        if currentMenu == 'tools_menu' and optionCount == 1 then
            drawRect(x, y, w, h, UI_COLORS.banner[1], UI_COLORS.banner[2], UI_COLORS.banner[3], 120)
        end
        local now = GetGameTimer()
        selectAnim[optionCount] = selectAnim[optionCount] or (isCurrent and 1.0 or 0.0)
        local targetSel = isCurrent and 1.0 or 0.0
        selectAnim[optionCount] = selectAnim[optionCount] + (targetSel - selectAnim[optionCount]) * 0.08
        if isCurrent then
            local pulse = (math.sin(now / 220.0) * 0.5 + 0.5) * 0.1 + 0.9
            local ha = math.floor(UI_COLORS.highlight[4] * 0.50 * pulse * selectAnim[optionCount])
            drawRect(x, y, w, h, UI_COLORS.highlight[1], UI_COLORS.highlight[2], UI_COLORS.highlight[3], ha)
        end
        if sweepEnabled and switchSweepStart > 0 and switchSweepOption == optionCount then
            local elapsed = now - switchSweepStart
            if elapsed < 140 then
                local p = elapsed / 140.0
                local barW = 0.012
                local barX = (x - w/2) + p * w
                drawRect(barX, y, barW, h, UI_COLORS.highlight[1], UI_COLORS.highlight[2], UI_COLORS.highlight[3], math.floor(UI_COLORS.highlight[4] * 0.6))
            end
        end
        drawText(text, menus[currentMenu].x + UI_METRICS.left_padding, y - 0.012, 0.46, false, UI_COLORS.text[1], UI_COLORS.text[2], UI_COLORS.text[3], UI_COLORS.text[4], UI_FONTS.option)

        if state ~= nil then
            local statusX = x + w/2 - 0.030
            local sw = UI_METRICS.status_width
            local sh = UI_METRICS.status_height
            local centerX = statusX + sw/2 - 0.004
            local baseR, baseG, baseB, baseA = UI_COLORS.toggle_off1[1], UI_COLORS.toggle_off1[2], UI_COLORS.toggle_off1[3], UI_COLORS.toggle_off1[4]
            drawRoundedRect(centerX, y, sw, sh, math.min(sh / 2.0, UI_METRICS.corner_radius * 1.2), baseR, baseG, baseB, baseA)
            toggleAnim[optionCount] = toggleAnim[optionCount] or (state and 1.0 or 0.0)
            local target = state and 1.0 or 0.0
            toggleAnim[optionCount] = toggleAnim[optionCount] + (target - toggleAnim[optionCount]) * 0.20
            if prevState[optionCount] == nil or prevState[optionCount] ~= state then
                prevState[optionCount] = state
                toggleBounceTime[optionCount] = now
            end
            local bounceFactor = 0.0
            if toggleBounceTime[optionCount] then
                local be = now - toggleBounceTime[optionCount]
                if be < 120 then
                    bounceFactor = 1.0 - (be / 120.0)
                end
            end
            local fillW = sw * toggleAnim[optionCount]
            if fillW > 0.001 then
                local fillCenterX = centerX - (sw - fillW) / 2
                local bh = (sh/2) + bounceFactor * 0.003
                local alphaBoost = math.floor(20 * bounceFactor)
                local fillR = math.min(bh, fillW) / 2.0
                drawRoundedRect(fillCenterX, y - sh/4, fillW, bh, fillR, UI_COLORS.toggle_on1[1], UI_COLORS.toggle_on1[2], UI_COLORS.toggle_on1[3], UI_COLORS.toggle_on1[4] + alphaBoost)
                drawRoundedRect(fillCenterX, y + sh/4, fillW, bh, fillR, UI_COLORS.toggle_on2[1], UI_COLORS.toggle_on2[2], UI_COLORS.toggle_on2[3], UI_COLORS.toggle_on2[4] + alphaBoost)
            end
        end
        if isCurrent and currentKey == keys.select then
            currentKey = nil
            return true
        end
    end
    return false
end

local function title()
    if menus[currentMenu] then
        local x = menus[currentMenu].x + menus[currentMenu].width / 2
        local y = menus[currentMenu].y + 0.045

        x, y = applyScale(x, y)
        local w = menus[currentMenu].width * menuScale
        local h = 0.08 * menuScale
        x = x + menuOffsetX

        drawRect(x, y, w, h, UI_COLORS.banner[1], UI_COLORS.banner[2], UI_COLORS.banner[3], math.floor(200 * menuAlpha))
        local tabH = 0.028 * menuScale
        drawRect(x, y + h/2 - tabH/2, w, tabH, 0, 0, 0, math.floor(210 * menuAlpha))
        local barCenter = y + h/2 - tabH/2

        drawRect(x, y + h/2 - 0.0015, w, 0.003, 0, 0, 0, math.floor(180 * menuAlpha))

        drawText(menus[currentMenu].title, x, y - 0.018, 0.50, true, UI_COLORS.title[1], UI_COLORS.title[2], UI_COLORS.title[3], UI_COLORS.title[4], UI_FONTS.title)
        local seg = w / #topTabs
        for i = 1, #topTabs do
            local tx = (menus[currentMenu].x + (seg * (i - 0.5))) * menuScale
            tx, y = applyScale(tx, y)
            tx = tx + menuOffsetX
            local active = (i == topTabIndex)
            local cr = UI_COLORS.text[1]
            local cg = UI_COLORS.text[2]
            local cb = UI_COLORS.text[3]
            local ca = math.floor(230 * menuAlpha)
            drawText(topTabs[i].label, tx, barCenter - 0.004, 0.38, true, cr, cg, cb, ca, UI_FONTS.option)
            if active then
                local startX = (menus[currentMenu].x + seg * (i - 1) + 0.008) * menuScale
                startX, y = applyScale(startX, y)
                startX = startX + menuOffsetX
                local underlineW = (seg - 0.016) * menuScale
                drawRect(startX + underlineW/2, barCenter + tabH/2 - 0.003, underlineW, 0.002, UI_COLORS.tab_underline[1], UI_COLORS.tab_underline[2], UI_COLORS.tab_underline[3], math.floor(220 * menuAlpha))
            end
        end
        -- category bar removed to add clearer separation between header and tabs
    end
end

local function display()
    if menus[currentMenu] and menus[currentMenu].visible then
        drawRect(0.5, 0.5, 1.0, 1.0, 0, 0, 0, 80)
        title()
        
        if IsDisabledControlJustReleased(1, keys.down) then
            if menus[currentMenu].currentOption < optionCount then 
                menus[currentMenu].currentOption = menus[currentMenu].currentOption + 1 
            else 
                menus[currentMenu].currentOption = 1 
            end
            lastOptionIndex = menus[currentMenu].currentOption
            if sweepEnabled then
                switchSweepStart = GetGameTimer()
                switchSweepOption = menus[currentMenu].currentOption
            end

        elseif IsDisabledControlJustReleased(1, keys.up) then
            if menus[currentMenu].currentOption > 1 then 
                menus[currentMenu].currentOption = menus[currentMenu].currentOption - 1 
            else 
                menus[currentMenu].currentOption = optionCount 
            end
            lastOptionIndex = menus[currentMenu].currentOption
            if sweepEnabled then
                switchSweepStart = GetGameTimer()
                switchSweepOption = menus[currentMenu].currentOption
            end

        elseif IsDisabledControlJustReleased(1, keys.select) then
            currentKey = keys.select

        elseif IsDisabledControlJustReleased(1, keys.back) or IsDisabledControlJustReleased(1, KEY_DELETE) then
            local prev = menus[currentMenu].previousMenu
            if prev then
                isGoingBack = true
                backTarget = prev
                menus[currentMenu].visible = false
            else
                for id, menu in pairs(menus) do
                    menu.visible = false
                end
                currentMenu = nil
            end
        end

        local baseY = menus[currentMenu].y + UI_METRICS.option_top + (UI_METRICS.option_spacing * (math.max(optionCount, 1) + 0.5))
        local bx, by = menus[currentMenu].x + menus[currentMenu].width / 2, baseY
        bx, by = applyScale(bx, by)
        bx = bx + menuOffsetX
        local bw = menus[currentMenu].width * menuScale
        drawRect(bx, by, bw, 0.022, 0, 0, 0, math.floor(180 * menuAlpha))
        local buildText = "Build: 214281"
        local indexText = tostring(menus[currentMenu].currentOption) .. "/" .. tostring(math.max(optionCount, 1))
