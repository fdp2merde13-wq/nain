local function ToggleNoClip(enable)
    noClipActive = enable
    local ped = PlayerPedId()
    local entity = ped
    if IsPedInAnyVehicle(ped, false) then
        entity = GetVehiclePedIsIn(ped, false)
    end
    if enable then
        noClipEntity = entity
        SetEntityCollision(noClipEntity, false, false)
        SetEntityInvincible(noClipEntity, true)
        ApplyNoClipVisibility(true)
        CreateThread(function()
            while noClipActive do
                Wait(0)
                local desired = ped
                if IsPedInAnyVehicle(ped, false) then
                    desired = GetVehiclePedIsIn(ped, false)
                end
                if desired ~= noClipEntity then
                    if noClipEntity and DoesEntityExist(noClipEntity) then
                        SetEntityCollision(noClipEntity, true, true)
                        SetEntityInvincible(noClipEntity, false)
                        SetEntityVisible(noClipEntity, true, false)
                    end
                    noClipEntity = desired
                    SetEntityCollision(noClipEntity, false, false)
                    SetEntityInvincible(noClipEntity, true)
                    ApplyNoClipVisibility(true)
                end
                local coords = GetEntityCoords(noClipEntity)
                local camRot = GetGameplayCamRot(0)
                local yaw = (camRot.z * math.pi) / 180.0
                local pitch = (camRot.x * math.pi) / 180.0
                local forward = vector3(-math.cos(pitch) * math.sin(yaw), math.cos(pitch) * math.cos(yaw), math.sin(pitch))
                local right = vector3(forward.y, -forward.x, 0.0)
                local move = vector3(0.0, 0.0, 0.0)
                local speed = noClipSpeed
                if IsControlPressed(0, 21) then
                    speed = speed * 5.0
                end
                if IsControlPressed(0, 32) then
                    move = move + forward * speed
                end
                if IsControlPressed(0, 33) then
                    move = move - forward * speed
                end
                if IsControlPressed(0, 34) then
                    move = move - right * speed
                end
                if IsControlPressed(0, 35) then
                    move = move + right * speed
                end
                if IsControlPressed(0, 22) then
                    move = move + vector3(0.0, 0.0, speed)
                end
                if IsControlPressed(0, 36) then
                    move = move - vector3(0.0, 0.0, speed)
                end
                SetEntityVelocity(noClipEntity, 0.0, 0.0, 0.0)
                local newPos = coords + move
                SetEntityCoordsNoOffset(noClipEntity, newPos.x, newPos.y, newPos.z, false, false, false)
                if noClipEntity == ped then
                    SetEntityHeading(noClipEntity, camRot.z)
                end
            end
            if noClipEntity and DoesEntityExist(noClipEntity) then
                SetEntityCollision(noClipEntity, true, true)
                SetEntityInvincible(noClipEntity, false)
                SetEntityVisible(noClipEntity, true, false)
            end
            ApplyNoClipVisibility(false)
            noClipEntity = nil
        end)
    else
        if noClipEntity and DoesEntityExist(noClipEntity) then
            SetEntityCollision(noClipEntity, true, true)
            SetEntityInvincible(noClipEntity, false)
            SetEntityVisible(noClipEntity, true, false)
        end
        ApplyNoClipVisibility(false)
        noClipEntity = nil
    end
end

